<!doctype html>
<html lang="{{ request.locale.iso_code }}"
      {% if settings.palette != 'pastel' %}data-palette="{{ settings.palette }}"{% endif %}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#FFF9F4">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &mdash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif -%}
    {%- if current_page != 1 %} &mdash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &mdash; {{ shop.name }}{% endunless -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- render 'meta-tags' -%}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <style>
    :root { --container-width: {{ settings.page_width }}px; }
    .container { max-width: var(--container-width); }
  </style>

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <script>
    window.themeSettings = {
      palette: {{ settings.palette | json }},
      bubblesEnabled: {{ settings.bubbles_enabled | json }},
      bubblesDensity: {{ settings.bubbles_density | json }},
      bubblesTrail: {{ settings.bubbles_trail | json }},
      shopCurrency: {{ shop.currency | json }},
      moneyFormat: {{ shop.money_format | json }},
      routes: {
        cart_url: {{ routes.cart_url | json }},
        cart_add_url: {{ routes.cart_add_url | json }},
        cart_change_url: {{ routes.cart_change_url | json }},
        search_url: {{ routes.search_url | json }},
        predictive_search_url: {{ routes.predictive_search_url | json }}
      }
    };
  </script>

  {{ content_for_header }}
</head>
<body class="template-{{ template.name | handle }}">
  <a class="visually-hidden" href="#main-content">{{ 'general.accessibility.skip_to_content' | t }}</a>

  {%- render 'bubble-field' -%}

  <div class="page-wrap">
    {%- section 'announcement-bar' -%}
    {%- section 'header' -%}

    <main id="main-content" role="main">
      {{ content_for_layout }}
    </main>

    {%- section 'footer' -%}
  </div>

  <script src="{{ 'bubbles.js' | asset_url }}" defer></script>
</body>
</html>
