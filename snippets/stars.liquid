{%- comment -%}
  Renders a 5-star rating row.
  Usage: {% render 'stars', rating: 4.7 %}
{%- endcomment -%}
{%- assign rounded = rating | default: 5 | times: 1.0 | round -%}
<span class="stars" aria-label="{{ rating }} étoiles sur 5">
  {%- for i in (1..5) -%}
    {%- if i <= rounded -%}★{%- else -%}☆{%- endif -%}
  {%- endfor -%}
</span>
