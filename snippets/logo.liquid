{%- comment -%}
  Renders the brand logo. Uses settings.logo if set, otherwise falls back to
  the SVG bubble logo + brand name + tagline from the design.
{%- endcomment -%}
<a href="{{ routes.root_url }}" class="site-logo" aria-label="{{ settings.brand_name | escape }}">
  {%- if settings.logo != blank -%}
    <img src="{{ settings.logo | image_url: width: 400 }}"
         width="{{ settings.logo_width }}"
         height="auto"
         alt="{{ settings.brand_name | escape }}"
         loading="eager">
  {%- else -%}
    <span style="display:flex; align-items:center; gap:8px;">
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
        <circle cx="18" cy="18" r="17" fill="var(--pink)"></circle>
        <circle cx="13" cy="14" r="4" fill="#fff" opacity="0.7"></circle>
        <circle cx="22" cy="20" r="3" fill="#fff" opacity="0.5"></circle>
        <circle cx="11" cy="22" r="2" fill="#fff" opacity="0.6"></circle>
        <circle cx="18" cy="18" r="17" fill="none" stroke="var(--ink)" stroke-width="1" opacity="0.15"></circle>
      </svg>
      <span style="line-height:1;">
        <span class="h-display" style="font-size:18px; letter-spacing:-0.01em; display:block;">
          {{- settings.brand_name | split: ' du ' | first -}}
        </span>
        <span style="font-size:10px; font-family:var(--font-mono); letter-spacing:0.18em; color:var(--ink-soft); display:block; margin-top:2px;">
          {{- settings.brand_tagline -}}
        </span>
      </span>
    </span>
  {%- endif -%}
</a>
