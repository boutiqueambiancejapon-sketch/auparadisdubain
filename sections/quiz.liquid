<section class="quiz-section" id="quiz-{{ section.id }}">
  <div class="container">
    <div class="quiz-section__inner">
      <div class="quiz-section__decor" aria-hidden="true"></div>

      <div class="quiz-section__copy">
        {%- if section.settings.eyebrow != blank -%}
          <div class="eyebrow" style="margin-bottom: 16px;">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="h-display quiz-section__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <p class="quiz-section__text">{{ section.settings.text }}</p>
        {%- endif -%}
      </div>

      <div class="quiz-card" data-quiz>
        {%- assign questions = section.blocks | where: 'type', 'question' -%}
        {%- assign total = questions.size -%}

        <div data-quiz-progress style="display:flex; gap:6px; margin-bottom:24px;">
          {%- for q in questions -%}
            <div class="quiz-card__bar{% if forloop.first %} is-active{% endif %}"></div>
          {%- endfor -%}
        </div>

        {%- for block in questions -%}
          <div class="quiz-card__step" data-quiz-step="{{ forloop.index0 }}"
               style="display: {% if forloop.first %}block{% else %}none{% endif %};"
               {{ block.shopify_attributes }}>
            <div class="eyebrow" style="margin-bottom: 12px;">
              Question {{ forloop.index }} / {{ total }}
            </div>
            <h3 class="h-display quiz-card__question">{{ block.settings.question }}</h3>
            <div class="quiz-card__options">
              {%- assign opts = block.settings.options | newline_to_br | split: '<br />' -%}
              {%- for opt in opts -%}
                {%- assign opt_clean = opt | strip -%}
                {%- if opt_clean != blank -%}
                  <button type="button" class="quiz-card__option" data-quiz-next>{{ opt_clean }}</button>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}

        <div class="quiz-card__step quiz-card__result" data-quiz-result style="display:none;">
          <div style="font-size: 48px; margin-bottom: 12px;">✿</div>
          <h3 class="h-display quiz-card__result-title">{{ section.settings.result_title }}</h3>
          <p class="quiz-card__result-text">{{ section.settings.result_text }}</p>
          <a href="{{ section.settings.result_url | default: '#' }}" class="btn">
            {{ section.settings.result_cta | default: 'Découvrir mon rituel →' }}
          </a>
          <div>
            <button type="button" class="quiz-card__restart" data-quiz-restart>Recommencer</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .quiz-section { padding: 100px 0; }
  .quiz-section__inner {
    display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;
    background: linear-gradient(135deg, var(--mint) 0%, var(--lilac) 100%);
    border-radius: var(--radius-xl); padding: 72px 64px;
    position: relative; overflow: hidden;
  }
  .quiz-section__decor {
    position: absolute; top: -100px; right: -100px; width: 360px; height: 360px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.6), transparent 70%);
    pointer-events: none;
  }
  .quiz-section__copy { position: relative; }
  .quiz-section__heading { font-size: clamp(40px, 5vw, 64px); margin-bottom: 20px; line-height: 0.95; }
  .quiz-section__text { font-size: 16px; color: var(--ink-soft); max-width: 360px; }

  .quiz-card {
    background: rgba(255,255,255,0.85); backdrop-filter: blur(20px);
    border-radius: var(--radius-lg); padding: 36px;
    position: relative;
  }
  .quiz-card__bar { flex: 1; height: 4px; border-radius: 2px; background: var(--line-strong); transition: background .25s; }
  .quiz-card__bar.is-active { background: var(--ink); }
  .quiz-card__question { font-size: 36px; margin-bottom: 24px; }
  .quiz-card__options { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .quiz-card__option {
    padding: 20px 18px; border-radius: var(--radius-md);
    background: rgba(255,255,255,0.6); border: 1.5px solid var(--line-strong);
    font-size: 15px; font-weight: 500; text-align: left;
    transition: all .25s;
  }
  .quiz-card__option:hover {
    background: var(--pink); border-color: var(--pink-deep); transform: translateY(-2px);
  }
  .quiz-card__result { text-align: center; }
  .quiz-card__result-title { font-size: 36px; margin-bottom: 12px; }
  .quiz-card__result-text { color: var(--ink-soft); margin-bottom: 24px; max-width: 380px; margin-left: auto; margin-right: auto; }
  .quiz-card__restart { margin-top: 16px; font-size: 13px; color: var(--ink-soft); text-decoration: underline; background: none; }

  @media (max-width: 900px) {
    .quiz-section { padding: 60px 0; }
    .quiz-section__inner { grid-template-columns: 1fr; gap: 40px; padding: 48px 28px; }
    .quiz-card { padding: 24px; }
    .quiz-card__question { font-size: 28px; }
    .quiz-card__options { grid-template-columns: 1fr; }
  }
</style>

<script>
  (function () {
    const root = document.getElementById('quiz-{{ section.id }}');
    if (!root) return;
    const steps = Array.from(root.querySelectorAll('[data-quiz-step]'));
    const bars = Array.from(root.querySelectorAll('.quiz-card__bar'));
    const result = root.querySelector('[data-quiz-result]');
    const restart = root.querySelector('[data-quiz-restart]');
    let current = 0;

    function show(idx) {
      steps.forEach((s, i) => { s.style.display = i === idx ? 'block' : 'none'; });
      bars.forEach((b, i) => b.classList.toggle('is-active', i <= idx));
      if (result) result.style.display = 'none';
    }
    function showResult() {
      steps.forEach(s => s.style.display = 'none');
      bars.forEach(b => b.classList.add('is-active'));
      if (result) result.style.display = 'block';
    }

    root.addEventListener('click', (e) => {
      if (e.target.matches('[data-quiz-next]')) {
        current += 1;
        if (current >= steps.length) showResult();
        else show(current);
      } else if (e.target.matches('[data-quiz-restart]')) {
        current = 0;
        show(0);
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Quiz rituel",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "· Quiz · 60 secondes" },
    { "type": "text", "id": "heading", "label": "Titre",
      "default": "Trouvez votre rituel idéal." },
    { "type": "textarea", "id": "text", "label": "Texte d'intro",
      "default": "Trois questions, une recommandation sur-mesure parmi nos références. Curieux de savoir ce que votre humeur révèle ?" },
    { "type": "header", "content": "Résultat" },
    { "type": "text",     "id": "result_title", "label": "Titre du résultat",   "default": "Le Rituel du Dimanche" },
    { "type": "textarea", "id": "result_text",  "label": "Description résultat",
      "default": "Cocooning, floral, durée moyenne : notre coffret signature est fait pour vous." },
    { "type": "text", "id": "result_cta", "label": "Texte du bouton", "default": "Découvrir mon rituel →" },
    { "type": "url",  "id": "result_url", "label": "Lien du bouton" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text",     "id": "question", "label": "Question" },
        { "type": "textarea", "id": "options",  "label": "Options (une par ligne)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quiz rituel",
      "blocks": [
        { "type": "question", "settings": {
          "question": "Votre humeur du soir ?",
          "options": "Cocooning\nÉnergique\nRomantique\nMéditatif"
        } },
        { "type": "question", "settings": {
          "question": "Une fragrance qui vous transporte ?",
          "options": "Florale\nGourmande\nBoisée\nAquatique"
        } },
        { "type": "question", "settings": {
          "question": "Votre temps idéal de bain ?",
          "options": "20 min express\n45 min rituel\n1h+ marathon\nVariable"
        } }
      ]
    }
  ]
}
{% endschema %}
