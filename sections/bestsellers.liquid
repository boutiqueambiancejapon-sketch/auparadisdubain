<section class="bestsellers">
  <div class="container">
    <div class="bestsellers__head">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <div class="eyebrow" style="margin-bottom: 12px;">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="h-serif bestsellers__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      <div class="bestsellers__nav">
        <button type="button" class="btn btn-sm btn-secondary bestsellers__arrow" data-scroll-prev aria-label="Précédent">←</button>
        <button type="button" class="btn btn-sm btn-secondary bestsellers__arrow" data-scroll-next aria-label="Suivant">→</button>
      </div>
    </div>

    {%- assign collection_handle = section.settings.collection -%}
    {%- assign source = collections[collection_handle] -%}
    {%- assign products_to_show = source.products | default: collections.all.products -%}
    {%- assign limit = section.settings.product_count | default: 4 -%}

    <div class="grid cols-4 bestsellers__grid" data-scroll-container>
      {%- for product in products_to_show limit: limit -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        {%- comment -%} Empty-state placeholder cards so the layout is visible in the editor {%- endcomment -%}
        {%- for i in (1..4) -%}
          <div class="card" style="padding: 18px;">
            {%- render 'placeholder', swatch: 'pink', label: 'best-seller' -%}
            <div style="margin-top: 16px;">
              <h3 class="h-serif" style="font-size: 20px;">Produit exemple</h3>
              <p style="color: var(--ink-soft); font-size: 13px;">Ajoutez des produits à la collection sélectionnée.</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .bestsellers { padding: 60px 0 100px; }
  .bestsellers__head {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 40px; gap: 24px; flex-wrap: wrap;
  }
  .bestsellers__heading { font-size: clamp(40px, 5vw, 64px); }
  .bestsellers__nav { display: flex; gap: 8px; }
  .bestsellers__arrow {
    width: 44px; height: 44px; padding: 0; border-radius: 50%;
    border-color: var(--line-strong);
  }

  @media (max-width: 900px) {
    .bestsellers { padding: 40px 0 60px; }
    .bestsellers__grid {
      grid-template-columns: repeat(4, 80%) !important;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 16px;
      margin: 0 -20px; padding-left: 20px; padding-right: 20px;
    }
    .bestsellers__grid > * { scroll-snap-align: start; }
  }
</style>

<script>
  (function () {
    const root = document.currentScript.closest('.bestsellers');
    if (!root) return;
    const grid = root.querySelector('[data-scroll-container]');
    const prev = root.querySelector('[data-scroll-prev]');
    const next = root.querySelector('[data-scroll-next]');
    if (!grid || !prev || !next) return;
    const step = () => Math.max(grid.clientWidth * 0.6, 280);
    prev.addEventListener('click', () => grid.scrollBy({ left: -step(), behavior: 'smooth' }));
    next.addEventListener('click', () => grid.scrollBy({ left:  step(), behavior: 'smooth' }));
  })();
</script>

{% schema %}
{
  "name": "Best-sellers",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "· Best-sellers" },
    { "type": "text", "id": "heading", "label": "Titre",
      "default": "Les favoris de la maison." },
    { "type": "collection", "id": "collection", "label": "Collection à afficher" },
    { "type": "range", "id": "product_count", "label": "Nombre de produits",
      "min": 2, "max": 12, "step": 1, "default": 4 }
  ],
  "presets": [
    { "name": "Best-sellers" }
  ]
}
{% endschema %}
