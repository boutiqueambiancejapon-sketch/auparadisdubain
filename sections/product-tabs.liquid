{%- liquid
  assign p = product
  assign default_blocks_size = section.blocks.size
-%}

<section class="product-tabs" id="product-tabs-{{ section.id }}">
  <div class="container product-tabs__container">
    <div class="product-tabs__nav" role="tablist">
      {%- for block in section.blocks -%}
        {%- assign tab_id = 'tab-' | append: section.id | append: '-' | append: forloop.index -%}
        {%- assign panel_id = 'panel-' | append: section.id | append: '-' | append: forloop.index -%}

        {%- assign tab_label = block.settings.label -%}
        {%- if block.type == 'reviews' -%}
          {%- assign reviews_count = p.metafields.reviews.rating_count.value -%}
          {%- if reviews_count > 0 -%}
            {%- assign tab_label = block.settings.label | append: ' (' | append: reviews_count | append: ')' -%}
          {%- endif -%}
        {%- endif -%}

        <button type="button"
                role="tab"
                id="{{ tab_id }}"
                class="product-tabs__tab {% if forloop.first %}is-active{% endif %}"
                aria-controls="{{ panel_id }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                {% unless forloop.first %}tabindex="-1"{% endunless %}
                {{ block.shopify_attributes }}>
          {{ tab_label }}
        </button>
      {%- endfor -%}
    </div>

    <div class="product-tabs__panels">
      {%- for block in section.blocks -%}
        {%- assign tab_id = 'tab-' | append: section.id | append: '-' | append: forloop.index -%}
        {%- assign panel_id = 'panel-' | append: section.id | append: '-' | append: forloop.index -%}

        <div id="{{ panel_id }}"
             role="tabpanel"
             aria-labelledby="{{ tab_id }}"
             class="product-tabs__panel {% if forloop.first %}is-active{% endif %}"
             {% unless forloop.first %}hidden{% endunless %}>

          {%- case block.type -%}

            {%- when 'description' -%}
              {%- assign lede = p.metafields.custom.lede -%}
              {%- if lede != blank -%}
                <p class="product-tabs__lede">{{ lede }}</p>
              {%- endif -%}
              <div class="product-tabs__rte">
                {{- p.description | default: block.settings.fallback_text -}}
              </div>

            {%- when 'ingredients' -%}
              {%- assign ingredients = p.metafields.custom.ingredients -%}
              {%- if ingredients != blank -%}
                <p style="margin-bottom: 16px;">{{ ingredients }}</p>
              {%- endif -%}
              {%- assign inci = p.metafields.custom.inci -%}
              {%- if inci != blank -%}
                <p style="font-size: 13px;"><strong style="color: var(--ink);">INCI complet :</strong> {{ inci }}</p>
              {%- elsif block.settings.fallback_text != blank -%}
                <div class="product-tabs__rte">{{ block.settings.fallback_text }}</div>
              {%- endif -%}

            {%- when 'ritual' -%}
              {%- assign ritual = p.metafields.custom.ritual -%}
              {%- if ritual != blank -%}
                <div class="product-tabs__rte">{{ ritual }}</div>
              {%- elsif block.settings.fallback_text != blank -%}
                <div class="product-tabs__rte">{{ block.settings.fallback_text }}</div>
              {%- endif -%}

            {%- when 'reviews' -%}
              <div id="reviews">
                {%- comment -%}
                  Hook for a Shopify review app (Judge.me, Loox, Yotpo,
                  shopify_product_reviews etc.). Falls back to a CTA
                  block if no app provides markup.
                {%- endcomment -%}
                <div class="product-tabs__reviews-app">
                  {{ p.metafields.reviews.markup | default: '' }}
                </div>
                <div class="product-tabs__reviews-fallback">
                  {%- if p.metafields.reviews.rating_count.value > 0 -%}
                    {%- render 'stars', rating: p.metafields.reviews.rating.value -%}
                    <p style="margin-top: 8px;">
                      {{ p.metafields.reviews.rating.value }} / 5 · {{ p.metafields.reviews.rating_count.value }} avis
                    </p>
                  {%- else -%}
                    <p style="color: var(--ink-soft);">Soyez la première personne à laisser un avis.</p>
                  {%- endif -%}
                </div>
              </div>

            {%- when 'custom' -%}
              <div class="product-tabs__rte">{{ block.settings.content }}</div>

          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .product-tabs { padding: 40px 0; border-top: 1px solid var(--line); }
  .product-tabs__container { max-width: 880px; }
  .product-tabs__nav {
    display: flex; gap: 8px; margin-bottom: 32px;
    border-bottom: 1px solid var(--line);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .product-tabs__nav::-webkit-scrollbar { display: none; }

  .product-tabs__tab {
    padding: 16px 20px; font-size: 14px; font-weight: 500;
    color: var(--ink-soft); cursor: pointer;
    border-bottom: 2px solid transparent; margin-bottom: -1px;
    background: none; white-space: nowrap;
    transition: color .2s, border-color .2s;
  }
  .product-tabs__tab:hover { color: var(--ink); }
  .product-tabs__tab.is-active { color: var(--ink); border-bottom-color: var(--ink); }

  .product-tabs__panel {
    min-height: 200px; font-size: 16px; line-height: 1.65; color: var(--ink-soft);
  }
  .product-tabs__panel[hidden] { display: none; }

  .product-tabs__lede {
    margin-bottom: 16px;
    font-family: var(--font-display); font-size: 22px; color: var(--ink);
  }
  .product-tabs__rte p + p { margin-top: 12px; }
  .product-tabs__rte ul, .product-tabs__rte ol { padding-left: 20px; display: flex; flex-direction: column; gap: 12px; margin-top: 12px; }
  .product-tabs__rte ol { list-style: decimal; }
  .product-tabs__rte ul { list-style: disc; }

  .product-tabs__reviews-fallback { padding: 24px; background: var(--bg-soft); border-radius: var(--radius-md); text-align: center; }
</style>

<script>
  (function () {
    const root = document.getElementById('product-tabs-{{ section.id }}');
    if (!root) return;
    const tabs = Array.from(root.querySelectorAll('[role="tab"]'));
    const panels = Array.from(root.querySelectorAll('[role="tabpanel"]'));

    function activate(idx) {
      tabs.forEach((t, i) => {
        const on = i === idx;
        t.classList.toggle('is-active', on);
        t.setAttribute('aria-selected', String(on));
        t.tabIndex = on ? 0 : -1;
      });
      panels.forEach((p, i) => {
        p.classList.toggle('is-active', i === idx);
        if (i === idx) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
    }

    tabs.forEach((tab, idx) => {
      tab.addEventListener('click', () => activate(idx));
      tab.addEventListener('keydown', (e) => {
        let next = idx;
        if (e.key === 'ArrowRight') next = (idx + 1) % tabs.length;
        else if (e.key === 'ArrowLeft') next = (idx - 1 + tabs.length) % tabs.length;
        else return;
        e.preventDefault();
        activate(next);
        tabs[next].focus();
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Onglets produit",
  "tag": "section",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "description",
      "name": "Description",
      "limit": 1,
      "settings": [
        { "type": "text",     "id": "label",         "label": "Libellé de l'onglet", "default": "Description" },
        { "type": "richtext", "id": "fallback_text", "label": "Texte par défaut",
          "info": "Affiché si la description du produit est vide.",
          "default": "<p>Façonné à la main dans nos ateliers.</p>" }
      ]
    },
    {
      "type": "ingredients",
      "name": "Ingrédients",
      "limit": 1,
      "settings": [
        { "type": "text",     "id": "label",         "label": "Libellé de l'onglet", "default": "Ingrédients" },
        { "type": "richtext", "id": "fallback_text", "label": "Texte par défaut",
          "info": "Affiché si les metafields custom.ingredients et custom.inci sont vides.",
          "default": "<p>Liste des ingrédients à compléter dans la fiche produit.</p>" }
      ]
    },
    {
      "type": "ritual",
      "name": "Rituel d'usage",
      "limit": 1,
      "settings": [
        { "type": "text",     "id": "label",         "label": "Libellé de l'onglet", "default": "Rituel d'usage" },
        { "type": "richtext", "id": "fallback_text", "label": "Texte par défaut",
          "default": "<ol><li>Faites couler un bain à 37°C.</li><li>Plongez le produit et observez sa danse.</li><li>Laissez infuser 2 minutes avant d'entrer.</li><li>Détendez-vous 20 à 30 minutes.</li></ol>" }
      ]
    },
    {
      "type": "reviews",
      "name": "Avis",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "label", "label": "Libellé de l'onglet", "default": "Avis" }
      ]
    },
    {
      "type": "custom",
      "name": "Onglet libre",
      "settings": [
        { "type": "text",     "id": "label",   "label": "Libellé de l'onglet", "default": "Onglet" },
        { "type": "richtext", "id": "content", "label": "Contenu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Onglets produit",
      "blocks": [
        { "type": "description" },
        { "type": "ingredients" },
        { "type": "ritual" },
        { "type": "reviews" }
      ]
    }
  ]
}
{% endschema %}
