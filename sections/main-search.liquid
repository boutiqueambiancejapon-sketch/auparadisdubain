<section class="search-page">
  <div class="container">
    <div class="search-page__head">
      <div class="eyebrow" style="margin-bottom: 12px;">· {{ 'search.title' | t }}</div>
      {%- if search.performed and search.terms != blank -%}
        <h1 class="h-display search-page__title">
          {{ 'search.results_for_html' | t: terms: search.terms }}
        </h1>
      {%- else -%}
        <h1 class="h-display search-page__title">Que cherchez-vous&nbsp;?</h1>
      {%- endif -%}
    </div>

    <form action="{{ routes.search_url }}" method="get" class="search-page__form">
      <input type="search" name="q" value="{{ search.terms | escape }}"
             placeholder="{{ 'general.search.placeholder' | t }}"
             aria-label="{{ 'general.search.placeholder' | t }}"
             autocomplete="off"
             autofocus>
      <button type="submit" class="btn btn-sm">{{ 'general.search.submit' | t }} →</button>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <div class="search-page__count eyebrow">
          · {{ search.results_count }} résultat{% if search.results_count > 1 %}s{% endif %}
        </div>

        {%- paginate search.results by 24 -%}
          <div class="search-page__results">
            {%- for item in search.results -%}
              {%- case item.object_type -%}
                {%- when 'product' -%}
                  {%- render 'product-card', product: item -%}
                {%- when 'article' -%}
                  <a href="{{ item.url }}" class="card search-result">
                    <div class="search-result__type">Article · Le Journal</div>
                    <h3 class="h-serif search-result__title">{{ item.title }}</h3>
                    <p class="search-result__excerpt">{{ item.excerpt_or_content | strip_html | truncate: 140 }}</p>
                  </a>
                {%- when 'page' -%}
                  <a href="{{ item.url }}" class="card search-result">
                    <div class="search-result__type">Page</div>
                    <h3 class="h-serif search-result__title">{{ item.title }}</h3>
                    <p class="search-result__excerpt">{{ item.content | strip_html | truncate: 140 }}</p>
                  </a>
              {%- endcase -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="collection-pagination" aria-label="Pagination">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="btn btn-sm btn-secondary">← Précédent</a>
              {%- endif -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="btn btn-sm btn-secondary">Suivant →</a>
              {%- endif -%}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}

      {%- else -%}
        <div class="search-page__empty">
          <p class="h-serif" style="font-size: 28px; margin-bottom: 12px;">
            {{ 'search.no_results_html' | t: terms: search.terms }}
          </p>
          <p style="color: var(--ink-soft); margin-bottom: 24px;">
            Essayez un autre mot-clé ou explorez le catalogue complet.
          </p>
          <a href="{{ routes.all_products_collection_url }}" class="btn">Voir tous les produits →</a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

<style>
  .search-page { padding: 60px 0 100px; }
  .search-page__head { margin-bottom: 32px; }
  .search-page__title { font-size: clamp(40px, 6vw, 80px); line-height: 0.95; }
  .search-page__title strong { font-style: italic; font-family: var(--font-display); font-weight: 500; color: var(--accent); }

  .search-page__form {
    display: flex; gap: 8px; padding: 6px;
    background: var(--bg-soft); border: 1px solid var(--line-strong);
    border-radius: 999px; max-width: 560px; margin-bottom: 32px;
  }
  .search-page__form input {
    flex: 1; background: transparent; border: 0; padding: 0 18px;
    height: 44px; outline: none; border-radius: 999px;
  }

  .search-page__count { margin-bottom: 24px; }
  .search-page__results { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 48px; }

  .search-result { padding: 24px; }
  .search-result__type { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 12px; }
  .search-result__title { font-size: 20px; margin-bottom: 8px; }
  .search-result__excerpt { font-size: 13px; color: var(--ink-soft); line-height: 1.5; }

  .search-page__empty { padding: 60px 24px; background: var(--bg-soft); border-radius: var(--radius-lg); text-align: center; }

  @media (max-width: 900px) {
    .search-page__results { grid-template-columns: repeat(2, 1fr); }
  }
</style>

{% schema %}
{
  "name": "Page recherche",
  "tag": "section",
  "settings": []
}
{% endschema %}
