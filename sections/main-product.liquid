{%- liquid
  assign p = product
  assign swatch = p.metafields.custom.swatch
  if swatch == blank
    assign swatch_palette = 'pink,vanilla,mint,lilac' | split: ','
    assign swatch_index = p.handle | size | modulo: 4
    assign swatch = swatch_palette[swatch_index]
  endif

  assign subtitle = p.metafields.custom.subtitle
  if subtitle == blank
    assign subtitle = p.description | strip_html | truncate: 120
  endif

  assign tag_label = p.metafields.custom.badge | default: p.tags.first
  assign collection_for_breadcrumb = collection | default: p.collections.first

  assign rating = p.metafields.reviews.rating.value | default: 5
  assign reviews_count = p.metafields.reviews.rating_count.value | default: 0

  assign current_variant = p.selected_or_first_available_variant
-%}

<div class="container product-page__breadcrumbs">
  {%- render 'breadcrumbs' -%}
</div>

<section class="product-main">
  <div class="container product-main__grid">
    <!-- Gallery -->
    <div class="product-gallery">
      <div class="product-gallery__main product-gallery__main--{{ swatch }}">
        <div class="wobble product-gallery__main-inner">
          {%- if p.featured_image != blank -%}
            <div class="product-gallery__image" data-gallery-main>
              {{ p.featured_image | image_url: width: 1200
                  | image_tag:
                      class: 'product-gallery__image-el',
                      widths: '400, 600, 900, 1200, 1600',
                      sizes: '(max-width: 900px) 100vw, 50vw',
                      alt: p.featured_image.alt | default: p.title,
                      loading: 'eager',
                      fetchpriority: 'high' }}
            </div>
          {%- else -%}
            {%- render 'placeholder', swatch: swatch, label: p.title | downcase, shape: 'circle' -%}
          {%- endif -%}
        </div>

        {%- if tag_label != blank -%}
          <span class="tag tag-{{ swatch }} product-gallery__tag" style="background: #fff;">{{ tag_label }}</span>
        {%- endif -%}

        <div class="product-gallery__bubbles" aria-hidden="true">
          <span class="product-gallery__bubble product-gallery__bubble--a"></span>
          <span class="product-gallery__bubble product-gallery__bubble--b"></span>
        </div>
      </div>

      {%- if p.images.size > 1 -%}
        <div class="product-gallery__thumbs" data-gallery-thumbs>
          {%- for image in p.images limit: 4 -%}
            <button type="button"
                    class="product-gallery__thumb {% if forloop.first %}is-active{% endif %}"
                    data-gallery-thumb
                    data-image-src="{{ image | image_url: width: 1200 }}"
                    data-image-alt="{{ image.alt | default: p.title | escape }}"
                    aria-label="Voir image {{ forloop.index }}">
              {{ image | image_url: width: 240 | image_tag: alt: image.alt | default: p.title, loading: 'lazy' }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="product-info">
      <div class="eyebrow product-info__eyebrow">
        {%- if tag_label != blank -%}{{ tag_label }}{%- endif -%}
        {%- if tag_label != blank and collection_for_breadcrumb != blank %} · {% endif -%}
        {%- if collection_for_breadcrumb != blank -%}{{ collection_for_breadcrumb.title }}{%- endif -%}
      </div>

      <h1 class="h-display product-info__title">{{ p.title }}</h1>

      {%- if subtitle != blank -%}
        <p class="product-info__subtitle">{{ subtitle }}</p>
      {%- endif -%}

      <div class="product-info__rating">
        {%- render 'stars', rating: rating -%}
        <span style="font-size: 13px; color: var(--ink-soft);">
          {{ rating }}{% if reviews_count > 0 %} · {{ reviews_count }} avis{% endif %}
        </span>
        {%- if reviews_count > 0 -%}
          <a href="#reviews" style="font-size: 13px; border-bottom: 1px solid currentColor;">{{ 'products.product.read_reviews' | t }}</a>
        {%- endif -%}
      </div>

      <div class="product-info__price" data-product-price>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="product-info__price-current">{{ current_variant.price | money }}</span>
          <span class="product-info__price-was">{{ current_variant.compare_at_price | money }}</span>
        {%- else -%}
          <span class="product-info__price-current">{{ current_variant.price | money }}</span>
        {%- endif -%}
      </div>

      <!-- Variant pickers, ATC, trust signals — Stage 5b -->
      <div data-product-form-slot></div>
    </div>
  </div>
</section>

<style>
  .product-page__breadcrumbs { padding: 24px 0; }
  .product-main { padding: 20px 0 80px; }
  .product-main__grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 60px; }

  /* Gallery */
  .product-gallery__main {
    position: relative; border-radius: var(--radius-xl); overflow: hidden;
    padding: 60px;
  }
  .product-gallery__main--pink    { background: #FFE9EE; }
  .product-gallery__main--vanilla { background: #FFF3DC; }
  .product-gallery__main--mint    { background: #E2F7EE; }
  .product-gallery__main--lilac   { background: #EAE3FC; }

  .product-gallery__main-inner { position: relative; }
  .product-gallery__image { position: relative; width: 100%; aspect-ratio: 1 / 1; border-radius: 50%; overflow: hidden; }
  .product-gallery__image-el { width: 100%; height: 100%; object-fit: cover; }

  .product-gallery__tag { position: absolute; top: 24px; left: 24px; z-index: 2; }

  .product-gallery__bubbles { position: absolute; inset: 0; pointer-events: none; }
  .product-gallery__bubble { position: absolute; border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #fff, rgba(255,255,255,0.3));
    border: 1px solid rgba(255,255,255,0.7);
  }
  .product-gallery__bubble--a { top: 30px; right: 40px; width: 70px; height: 70px; animation: wobble 5s ease-in-out infinite; }
  .product-gallery__bubble--b { bottom: 50px; left: 30px; width: 40px; height: 40px; animation: wobble 7s ease-in-out infinite reverse; }

  .product-gallery__thumbs {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 16px;
  }
  .product-gallery__thumb {
    border: 2px solid transparent; border-radius: var(--radius-md);
    padding: 0; overflow: hidden; aspect-ratio: 1 / 1;
    background: var(--bg-soft); cursor: pointer; transition: border-color .2s;
  }
  .product-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .product-gallery__thumb.is-active { border-color: var(--ink); }

  /* Info */
  .product-info { position: sticky; top: 100px; align-self: start; }
  .product-info__eyebrow { margin-bottom: 12px; }
  .product-info__title { font-size: clamp(48px, 6vw, 72px); line-height: 0.95; margin-bottom: 16px; }
  .product-info__subtitle {
    font-size: 18px; color: var(--ink-soft); margin-bottom: 20px;
    font-family: var(--font-display);
  }
  .product-info__rating { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
  .product-info__price { font-size: 36px; font-weight: 600; margin-bottom: 32px; display: flex; align-items: baseline; gap: 12px; }
  .product-info__price-was { font-size: 18px; color: var(--ink-mute); text-decoration: line-through; font-weight: 400; }

  @media (max-width: 900px) {
    .product-main { padding: 8px 0 48px; }
    .product-main__grid { grid-template-columns: 1fr; gap: 32px; }
    .product-gallery__main { padding: 32px; }
    .product-info { position: static; }
    .product-info__title { font-size: 40px; }
    .product-info__price { font-size: 28px; }
  }
</style>

<script>
  (function () {
    const main = document.querySelector('[data-gallery-main] img');
    const thumbs = document.querySelectorAll('[data-gallery-thumb]');
    if (!main || !thumbs.length) return;
    thumbs.forEach((t) => {
      t.addEventListener('click', () => {
        thumbs.forEach((x) => x.classList.remove('is-active'));
        t.classList.add('is-active');
        main.src = t.dataset.imageSrc;
        main.alt = t.dataset.imageAlt;
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Page produit",
  "tag": "section",
  "settings": []
}
{% endschema %}
