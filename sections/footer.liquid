<footer class="site-footer">
  <div class="site-footer__bubbles" aria-hidden="true">
    <svg viewBox="0 0 1200 400" preserveAspectRatio="none">
      <circle cx="100" cy="350" r="60" fill="#fff"></circle>
      <circle cx="220" cy="320" r="40" fill="#fff"></circle>
      <circle cx="350" cy="380" r="80" fill="#fff"></circle>
      <circle cx="900" cy="340" r="50" fill="#fff"></circle>
      <circle cx="1050" cy="360" r="70" fill="#fff"></circle>
    </svg>
  </div>

  <div class="container site-footer__inner">
    <div class="grid cols-4 site-footer__cols">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'brand' -%}
            <div {{ block.shopify_attributes }}>
              <div class="h-display" style="font-size: 28px; margin-bottom: 12px;">
                {{ block.settings.heading | default: settings.brand_name }}
              </div>
              <p style="opacity: 0.7; font-size: 14px; line-height: 1.6;">
                {{ block.settings.text }}
              </p>
              {%- if settings.social_instagram != blank or settings.social_facebook != blank or settings.social_pinterest != blank or settings.social_tiktok != blank -%}
                <div class="site-footer__social">
                  {%- if settings.social_instagram != blank -%}
                    <a href="{{ settings.social_instagram }}" rel="noopener" aria-label="Instagram">Instagram</a>
                  {%- endif -%}
                  {%- if settings.social_facebook != blank -%}
                    <a href="{{ settings.social_facebook }}" rel="noopener" aria-label="Facebook">Facebook</a>
                  {%- endif -%}
                  {%- if settings.social_pinterest != blank -%}
                    <a href="{{ settings.social_pinterest }}" rel="noopener" aria-label="Pinterest">Pinterest</a>
                  {%- endif -%}
                  {%- if settings.social_tiktok != blank -%}
                    <a href="{{ settings.social_tiktok }}" rel="noopener" aria-label="TikTok">TikTok</a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>

          {%- when 'menu' -%}
            <div {{ block.shopify_attributes }}>
              <h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
              <ul class="site-footer__links">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>

          {%- when 'newsletter' -%}
            <div {{ block.shopify_attributes }}>
              <h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
              <p style="opacity: 0.7; font-size: 14px; line-height: 1.6; margin-bottom: 16px;">
                {{ block.settings.text }}
              </p>
              {%- form 'customer', class: 'site-footer__newsletter' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="email" name="contact[email]"
                       placeholder="{{ 'general.newsletter.placeholder' | t }}"
                       aria-label="{{ 'general.newsletter.label' | t }}"
                       required>
                <button type="submit" class="btn btn-sm" style="background: var(--pink-deep); color: var(--ink);">
                  {{ 'general.newsletter.submit' | t }}
                </button>
                {%- if form.posted_successfully? -%}
                  <p style="font-size: 12px; margin-top: 8px; opacity: 0.8;">{{ 'general.newsletter.success' | t }}</p>
                {%- endif -%}
              {%- endform -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <span>{{ 'footer.copyright' | t: year: 'now' | date: '%Y', shop_name: shop.name }}{%- if section.settings.legal_info != blank -%} · {{ section.settings.legal_info }}{%- endif -%}</span>
      <span>
        {%- if shop.policies.terms_of_service -%}
          <a href="{{ shop.policies.terms_of_service.url }}">{{ shop.policies.terms_of_service.title }}</a> ·
        {%- endif -%}
        {%- if shop.policies.legal_notice -%}
          <a href="{{ shop.policies.legal_notice.url }}">{{ shop.policies.legal_notice.title }}</a> ·
        {%- endif -%}
        {%- if shop.policies.privacy_policy -%}
          <a href="{{ shop.policies.privacy_policy.url }}">{{ shop.policies.privacy_policy.title }}</a>
        {%- endif -%}
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 80px;
    background: var(--ink); color: var(--bg);
    padding: 80px 0 40px;
    position: relative; overflow: hidden;
  }
  .site-footer__bubbles {
    position: absolute; inset: 0; opacity: 0.08;
    pointer-events: none;
  }
  .site-footer__bubbles svg { width: 100%; height: 100%; }
  .site-footer__inner { position: relative; }
  .site-footer__cols { gap: 48px; }
  .site-footer__heading {
    font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase;
    margin-bottom: 16px; font-family: var(--font-mono); font-weight: 500;
  }
  .site-footer__links { list-style: none; display: flex; flex-direction: column; gap: 10px; font-size: 14px; opacity: 0.8; }
  .site-footer__links a:hover { opacity: 1; }
  .site-footer__social { display: flex; gap: 14px; margin-top: 20px; font-size: 13px; opacity: 0.8; }
  .site-footer__social a { border-bottom: 1px solid currentColor; padding-bottom: 1px; }
  .site-footer__newsletter { display: flex; gap: 6px; flex-wrap: wrap; }
  .site-footer__newsletter input { flex: 1; min-width: 160px; background: rgba(255,255,255,0.06); color: var(--bg); border-color: rgba(255,255,255,0.2); }
  .site-footer__newsletter input::placeholder { color: rgba(255,255,255,0.5); }
  .site-footer__bottom {
    margin-top: 60px; padding-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    display: flex; justify-content: space-between; gap: 24px;
    font-size: 12px; opacity: 0.6; flex-wrap: wrap;
  }
  .site-footer__bottom a:hover { opacity: 1; }

  @media (max-width: 900px) {
    .site-footer { padding: 60px 0 32px; margin-top: 60px; }
    .site-footer__cols { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 600px) {
    .site-footer__cols { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Pied de page",
  "settings": [
    {
      "type": "text",
      "id": "legal_info",
      "label": "Mention légale (SIRET, etc.)",
      "default": "SIRET 928 471 632 00018"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Bloc marque",
      "limit": 1,
      "settings": [
        { "type": "text",     "id": "heading", "label": "Titre", "default": "Au Paradis du Bain" },
        { "type": "richtext", "id": "text",    "label": "Description",
          "default": "<p>Cosmétiques de bain artisanaux, bio, vegan et d'origine contrôlée. Façonnés en Provence depuis 2018.</p>" }
      ]
    },
    {
      "type": "menu",
      "name": "Colonne menu",
      "settings": [
        { "type": "text",      "id": "heading", "label": "Titre", "default": "Boutique" },
        { "type": "link_list", "id": "menu",    "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text",     "id": "heading", "label": "Titre", "default": "Le Journal" },
        { "type": "richtext", "id": "text",    "label": "Texte",
          "default": "<p>Une lettre par mois : nouveautés, conseils rituels, accès aux ventes privées.</p>" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "brand" },
      { "type": "menu", "settings": { "heading": "Boutique" } },
      { "type": "menu", "settings": { "heading": "Maison" } },
      { "type": "menu", "settings": { "heading": "Service client" } }
    ]
  }
}
{% endschema %}
