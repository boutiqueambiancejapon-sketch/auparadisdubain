<section class="related-collections">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h3 class="h-serif related-collections__heading">{{ section.settings.heading }}</h3>
    {%- endif -%}

    <div class="grid cols-5 related-collections__grid">
      {%- assign limit = section.settings.limit | default: 5 -%}
      {%- assign mode = section.settings.mode | default: 'auto' -%}

      {%- if mode == 'manual' and section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign col = collections[block.settings.collection] -%}
          {%- assign sw = block.settings.swatch | default: col.metafields.custom.swatch | default: 'pink' -%}
          {%- if col != blank -%}
            <a href="{{ col.url }}" class="related-collection-card" {{ block.shopify_attributes }}>
              <div class="related-collection-card__media related-collection-card__media--{{ sw }}">
                {%- if col.featured_image != blank -%}
                  {{ col.featured_image | image_url: width: 400 | image_tag: alt: col.title, loading: 'lazy' }}
                {%- endif -%}
              </div>
              <div>
                <div class="related-collection-card__title">{{ col.title }}</div>
                <div class="related-collection-card__count">{{ col.products_count }} produits</div>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}

      {%- else -%}
        {%- comment -%} Auto mode: every shop collection except the current one {%- endcomment -%}
        {%- assign current_handle = collection.handle -%}
        {%- assign shown = 0 -%}
        {%- for col in collections -%}
          {%- if shown >= limit -%}{%- break -%}{%- endif -%}
          {%- if col.handle == current_handle -%}{%- continue -%}{%- endif -%}
          {%- if col.handle == 'all' -%}{%- continue -%}{%- endif -%}
          {%- assign sw = col.metafields.custom.swatch | default: 'pink' -%}
          <a href="{{ col.url }}" class="related-collection-card">
            <div class="related-collection-card__media related-collection-card__media--{{ sw }}">
              {%- if col.featured_image != blank -%}
                {{ col.featured_image | image_url: width: 400 | image_tag: alt: col.title, loading: 'lazy' }}
              {%- endif -%}
            </div>
            <div>
              <div class="related-collection-card__title">{{ col.title }}</div>
              <div class="related-collection-card__count">{{ col.products_count }} produits</div>
            </div>
          </a>
          {%- assign shown = shown | plus: 1 -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .related-collections { padding: 60px 0; background: var(--bg-soft); }
  .related-collections__heading { font-size: 36px; margin-bottom: 24px; }

  .related-collection-card {
    padding: 20px; border-radius: var(--radius-md);
    background: #fff; display: flex; flex-direction: column; gap: 12px;
    transition: transform .35s cubic-bezier(.34,1.56,.64,1);
  }
  .related-collection-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .related-collection-card__media {
    width: 100%; aspect-ratio: 1 / 1; border-radius: 50%;
    overflow: hidden; position: relative;
  }
  .related-collection-card__media img { width: 100%; height: 100%; object-fit: cover; }
  .related-collection-card__media--pink    { background: radial-gradient(circle at 30% 30%, #fff, var(--pink)); }
  .related-collection-card__media--vanilla { background: radial-gradient(circle at 30% 30%, #fff, var(--vanilla)); }
  .related-collection-card__media--mint    { background: radial-gradient(circle at 30% 30%, #fff, var(--mint)); }
  .related-collection-card__media--lilac   { background: radial-gradient(circle at 30% 30%, #fff, var(--lilac)); }

  .related-collection-card__title { font-weight: 600; font-size: 14px; }
  .related-collection-card__count { font-size: 12px; color: var(--ink-soft); }

  @media (max-width: 900px) {
    .related-collections__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

{% schema %}
{
  "name": "Autres collections",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Autres collections" },
    {
      "type": "select", "id": "mode", "label": "Mode",
      "options": [
        { "value": "auto",   "label": "Automatique (autres collections du shop)" },
        { "value": "manual", "label": "Manuel (depuis les blocs)" }
      ],
      "default": "auto"
    },
    {
      "type": "range", "id": "limit", "label": "Nombre maximum",
      "min": 3, "max": 8, "step": 1, "default": 5,
      "info": "Utilisé en mode automatique."
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        {
          "type": "select", "id": "swatch", "label": "Couleur",
          "options": [
            { "value": "pink",    "label": "Rose" },
            { "value": "vanilla", "label": "Vanille" },
            { "value": "mint",    "label": "Mint" },
            { "value": "lilac",   "label": "Lilas" }
          ],
          "default": "pink"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Autres collections" }
  ]
}
{% endschema %}
