<section class="hero">
  <div class="hero__blob hero__blob--pink" aria-hidden="true"></div>
  <div class="hero__blob hero__blob--mint" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <div class="eyebrow" style="margin-bottom: 20px;">{{ section.settings.eyebrow }}</div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="h-display hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p class="hero__text">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.settings.cta_primary_label != blank or section.settings.cta_secondary_label != blank -%}
        <div class="hero__cta">
          {%- if section.settings.cta_primary_label != blank -%}
            <a class="btn" href="{{ section.settings.cta_primary_link | default: routes.all_products_collection_url }}">
              {{ section.settings.cta_primary_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.cta_secondary_label != blank -%}
            <a class="btn btn-secondary" href="{{ section.settings.cta_secondary_link | default: '#' }}">
              {{ section.settings.cta_secondary_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="hero__proof">
        {%- if section.settings.show_rating -%}
          <div>
            {%- render 'stars', rating: section.settings.rating_value -%}
            <div class="hero__proof-text">
              <strong>{{ section.settings.rating_value }} / 5</strong> · {{ section.settings.rating_count }}
            </div>
          </div>
          <div class="hero__proof-divider"></div>
        {%- endif -%}
        {%- if section.settings.cert_label != blank -%}
          <div class="hero__proof-text">
            <strong>{{ section.settings.cert_label }}</strong><br>
            {{ section.settings.cert_sub }}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="hero__visual">
      <div class="wobble hero__main">
        {%- render 'placeholder',
            swatch: section.settings.main_swatch,
            label: 'hero',
            shape: 'circle',
            image: section.settings.main_image -%}
      </div>

      <div class="spin-slow hero__ring" aria-hidden="true">
        <svg viewBox="0 0 400 400">
          <defs>
            <path id="hero-circ" d="M 200,200 m -180,0 a 180,180 0 1,1 360,0 a 180,180 0 1,1 -360,0"></path>
          </defs>
          <text font-family="var(--font-mono)" font-size="11" letter-spacing="6" fill="var(--ink-soft)">
            <textPath href="#hero-circ">{{ section.settings.ring_text }}</textPath>
          </text>
        </svg>
      </div>

      <div class="hero__chip hero__chip--top">
        {%- render 'placeholder', swatch: section.settings.chip1_swatch, label: section.settings.chip1_label, shape: 'circle', small: true, image: section.settings.chip1_image -%}
      </div>
      <div class="hero__chip hero__chip--bottom">
        {%- render 'placeholder', swatch: section.settings.chip2_swatch, label: section.settings.chip2_label, shape: 'circle', small: true, image: section.settings.chip2_image -%}
      </div>
    </div>
  </div>
</section>

<style>
  .hero { position: relative; padding: 60px 0 100px; overflow: hidden; }
  .hero__blob { position: absolute; border-radius: 50%; filter: blur(20px); pointer-events: none; }
  .hero__blob--pink { top: -80px; right: -80px; width: 380px; height: 380px;
    background: radial-gradient(circle at 30% 30%, var(--pink), transparent 70%); opacity: 0.6; }
  .hero__blob--mint { bottom: -60px; left: -100px; width: 320px; height: 320px;
    background: radial-gradient(circle at 60% 40%, var(--mint), transparent 70%); opacity: 0.5; }

  .hero__inner {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 60px; align-items: center;
  }
  .hero__heading { font-size: clamp(56px, 8vw, 112px); margin-bottom: 24px; }
  .hero__heading .wavy { display: inline-block; }
  .hero__text { font-size: 18px; line-height: 1.55; color: var(--ink-soft); max-width: 480px; margin-bottom: 36px; }
  .hero__cta { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero__proof { display: flex; gap: 36px; margin-top: 48px; align-items: center; }
  .hero__proof-text { font-size: 13px; color: var(--ink-soft); margin-top: 4px; line-height: 1.5; }
  .hero__proof-text strong { color: var(--ink); }
  .hero__proof-divider { width: 1px; height: 36px; background: var(--line-strong); }

  .hero__visual { position: relative; aspect-ratio: 1 / 1.05; }
  .hero__main { position: absolute; inset: 5%; border-radius: 50%; overflow: hidden; }
  .hero__ring { position: absolute; inset: 0; pointer-events: none; }
  .hero__ring svg { width: 100%; height: 100%; }
  .hero__chip { position: absolute; }
  .hero__chip--top { top: 8%; right: 2%; width: 110px; height: 110px; animation: wobble 5s ease-in-out infinite; }
  .hero__chip--bottom { bottom: 6%; left: 4%; width: 90px; height: 90px; animation: wobble 7s ease-in-out infinite reverse; }

  @media (max-width: 900px) {
    .hero { padding: 40px 0 60px; }
    .hero__inner { grid-template-columns: 1fr; gap: 40px; }
    .hero__visual { max-width: 480px; margin: 0 auto; aspect-ratio: 1 / 1; }
    .hero__proof { margin-top: 32px; flex-wrap: wrap; gap: 20px; }
  }
</style>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow",  "default": "✿ Nouvelle collection · Printemps 26" },
    { "type": "richtext", "id": "heading",  "label": "Titre",
      "default": "<p>Le bain,<br/><span class=\"wavy\">art doux</span><br/>de se retrouver.</p>" },
    { "type": "richtext", "id": "text",     "label": "Texte d'intro",
      "default": "<p>Bombes effervescentes, sels infusés, savons saponifiés à froid — façonnés à la main dans nos ateliers de Grasse avec des ingrédients bio, vegan et d'origine contrôlée.</p>" },

    { "type": "header",   "content": "Boutons" },
    { "type": "text",     "id": "cta_primary_label",   "label": "CTA principal",   "default": "Explorer les collections →" },
    { "type": "url",      "id": "cta_primary_link",    "label": "Lien CTA principal" },
    { "type": "text",     "id": "cta_secondary_label", "label": "CTA secondaire",  "default": "Trouver mon rituel" },
    { "type": "url",      "id": "cta_secondary_link",  "label": "Lien CTA secondaire" },

    { "type": "header",   "content": "Preuve sociale" },
    { "type": "checkbox", "id": "show_rating",  "label": "Afficher la note",  "default": true },
    { "type": "text",     "id": "rating_value", "label": "Note",              "default": "4,9" },
    { "type": "text",     "id": "rating_count", "label": "Nombre d'avis",     "default": "8 412 avis vérifiés" },
    { "type": "text",     "id": "cert_label",   "label": "Certification",     "default": "Cosmos Organic" },
    { "type": "text",     "id": "cert_sub",     "label": "Sous-titre cert.",  "default": "Certifié bio depuis 2019" },

    { "type": "header",   "content": "Visuel principal" },
    { "type": "image_picker", "id": "main_image",  "label": "Image principale" },
    {
      "type": "select", "id": "main_swatch", "label": "Couleur de fond", "default": "pink",
      "options": [
        { "value": "pink",    "label": "Rose" },
        { "value": "vanilla", "label": "Vanille" },
        { "value": "mint",    "label": "Mint" },
        { "value": "lilac",   "label": "Lilas" }
      ]
    },
    { "type": "text", "id": "ring_text", "label": "Texte qui tourne autour",
      "default": "✿ BIO · VEGAN · ORIGINE CONTRÔLÉE · ARTISANAL · MADE IN FRANCE · ✿ BIO · VEGAN · ORIGINE CONTRÔLÉE · ARTISANAL ·" },

    { "type": "header", "content": "Pastilles flottantes" },
    { "type": "image_picker", "id": "chip1_image",  "label": "Image pastille 1" },
    { "type": "text",         "id": "chip1_label",  "label": "Légende pastille 1", "default": "sel" },
    { "type": "select", "id": "chip1_swatch", "label": "Couleur pastille 1", "default": "mint",
      "options": [
        { "value": "pink", "label": "Rose" }, { "value": "vanilla", "label": "Vanille" },
        { "value": "mint", "label": "Mint" }, { "value": "lilac", "label": "Lilas" }
      ]
    },
    { "type": "image_picker", "id": "chip2_image",  "label": "Image pastille 2" },
    { "type": "text",         "id": "chip2_label",  "label": "Légende pastille 2", "default": "savon" },
    { "type": "select", "id": "chip2_swatch", "label": "Couleur pastille 2", "default": "vanilla",
      "options": [
        { "value": "pink", "label": "Rose" }, { "value": "vanilla", "label": "Vanille" },
        { "value": "mint", "label": "Mint" }, { "value": "lilac", "label": "Lilas" }
      ]
    }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
